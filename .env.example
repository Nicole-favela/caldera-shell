
# URL where your CALDERA server is running. change to your ip
CALDERA_URL=http://localhost:8888

# API key for red agent
CALDERA_API_KEY=YOURKEY

# Agent group to target (red or blue)
CALDERA_GROUP=red

# ─── OLLAMA / LLM ───────────────────────────────────────────────
# URL where Ollama is running (default port 11434)
OLLAMA_API_URL=http://localhost:11434

# Model to use — must be pulled via `ollama pull <model>`
OLLAMA_MODEL=llama3.1

